# Copy this file to .env and fill in your own Coinbase credentials.
# Do not commit .env or private key files.

PORT=8080

COINBASE_API_KEY_NAME=organizations/XXX

# Recommended: keep the downloaded PEM file separate and point to it here.
# Relative paths are resolved from the crypto-paper-bot folder.
COINBASE_API_PRIVATE_KEY_FILE=./coinbase_api_key.json

# Alternative: paste the key directly with \n escapes instead of using a file.
# COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----\n"

LIVE_TRADING_CONFIRM=I_UNDERSTAND_THIS_PLACES_REAL_ORDERS

OANDA_ENV=practice
OANDA_API_BASE=https://api-fxpractice.oanda.com
OANDA_ACCOUNT_ID=XXX-XXX-XXXXXXXX-XXX
OANDA_API_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OANDA_DEMO_TRADING_ENABLED=true
